  "keyFeatures": [
    "Archetype-based entity storage with 16KB chunks for optimal cache efficiency",
    "High-performance queries with lambda, inline, and enumerator APIs",
    "Optional multithreaded parallel queries via ZeroAllocJobScheduler",
    "CommandBuffers for deferred structural changes",
    "Optional event system for component lifecycle hooks",
    "Pure-ECS mode for maximum performance without entity world references",
    "Generic and non-generic API for flexibility",
    "AOT-friendly design for Unity and other platforms",
    "Supports .NET Standard 2.1, .NET 6, and .NET 8"
  ],
